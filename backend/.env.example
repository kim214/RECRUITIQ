PORT=3001
JWT_SECRET=change-this-to-a-long-random-secret

# ─── Supabase (get from: Project Settings → API) ───
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...paste-service-role-key-here

# ─── AI (pick ONE provider — see AI_SETUP.md) ───

# FREE — Groq (recommended): https://console.groq.com
GROQ_API_KEY=
LLM_PROVIDER=groq

# OpenAI (paid): https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# LLM_PROVIDER=openai

# FREE — Google Gemini: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# LLM_PROVIDER=gemini

# FREE local only — Ollama: https://ollama.com
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=llama3.2

# Optional Python AI microservice (local / Railway)
AI_SERVICE_URL=http://localhost:8000
