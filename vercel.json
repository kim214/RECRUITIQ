{
  "version": 2,
  "name": "reqruit-iq",
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/frontend/(.*)", "dest": "/frontend/$1" },
    { "src": "/", "dest": "/frontend/home/index.html" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
